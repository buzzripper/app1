{
	"Logging": {
		"LogLevel": {
			"Default": "Information",
			"Microsoft": "Warning",
			"Microsoft.Hosting.Lifetime": "Information",
			"Microsoft.Identity.Web.TokenAcquisition": "Error",
			"Yarp": "Warning"
		},
		"File": {
			"Enabled": true,
			"Path": "logs/portal.log"
		}
	},
	"XXXOTEL_EXPORTER_OTLP_ENDPOINT": "",
	"Cors": {
		"AllowedOrigins": [ "https://*.localhost:4200", "https://localhost:4200", "https://*.localhost:4201", "https://localhost:4201" ]
	},
	"DataConfig": {
		"ConnectionString": "Server=.;Database=App1;Trusted_Connection=True;TrustServerCertificate=True"
	},
	"ServiceClients": {
		"Auth": {
			"Url": "https://localhost:5002"
		},
		"App1": {
			"Url": "https://localhost:5003"
		}
	},
	"ReverseProxy": {
		"Routes": {
			//"app-ping": {
			//	"ClusterId": "app-cluster",
			//	"Match": {
			//		"Path": "/api/app/ping"
			//	},
			//	"Transforms": [
			//		{
			//			"PathSet": "/ping"
			//		}
			//	]
			//},
			//"app-health": {
			//	"ClusterId": "app-cluster",
			//	"Match": {
			//		"Path": "/api/app/health"
			//	},
			//	"Transforms": [
			//		{
			//			"PathSet": "/health"
			//		}
			//	]
			//},
			"auth-api": {
				"ClusterId": "auth-cluster",
				"Match": {
					"Path": "/api/auth/{**catch-all}"
				},
				"Transforms": [
					{
						"PathPattern": "/api/auth/{**catch-all}"
					}
				]
			},
			//"app-api": {
			//	"ClusterId": "app-cluster",
			//	"Match": {
			//		"Path": "/api/app/{**catch-all}"
			//	},
			//	"Transforms": [
			//		{
			//			"PathPattern": "/api/app/{**catch-all}"
			//		}
			//	]
			//},
			"adagent-ping": {
				"ClusterId": "adagent-cluster",
				"Match": {
					"Path": "/api/adagent/ping"
				},
				"Transforms": [
					{
						"PathSet": "/ping"
					}
				]
			},
			"adagent-health": {
				"ClusterId": "adagent-cluster",
				"Match": {
					"Path": "/api/adagent/health"
				},
				"Transforms": [
					{
						"PathSet": "/health"
					}
				]
			},
			"adagent-api": {
				"ClusterId": "adagent-cluster",
				"Match": { "Path": "/api/adagent/{**catch-all}" },
				"Transforms": [
					{
						"PathPattern": "/api/adagent/{**catch-all}"
					}
				]
			},
			"integration-ping": {
				"ClusterId": "integration-cluster",
				"Match": {
					"Path": "/api/integration/ping"
				},
				"Transforms": [
					{
						"PathSet": "/ping"
					}
				]
			},
			"integration-health": {
				"ClusterId": "integration-cluster",
				"Match": {
					"Path": "/api/integration/health"
				},
				"Transforms": [
					{
						"PathSet": "/health"
					}
				]
			},
			"integration-api": {
				"ClusterId": "integration-cluster",
				"Match": { "Path": "/api/integration/{**catch-all}" },
				"Transforms": [
					{
						"PathPattern": "/api/integration/{**catch-all}"
					}
				]
			}
		},
		"Clusters": {
			"auth-cluster": {
				"Destinations": {
					"auth-destination": {
						"Address": "https+http://auth-server"
					}
				}
			},
			"app-cluster": {
				"Destinations": {
					"app-destination": {
						"Address": "https+http://app-server"
					}
				}
			},
			"adagent-cluster": {
				"Destinations": {
					"adagent-destination": {
						"Address": "https+http://adagent-server"
					}
				}
			},
			"integration-cluster": {
				"Destinations": {
					"integration-destination": {
						"Address": "https+http://integration-server"
					}
				}
			}
		}
	}
}
